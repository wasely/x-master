OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=X Master
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase pgvector — create a free project at supabase.com
# Copy URL and service_role key from: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# HuggingFace — free token from huggingface.co/settings/tokens
# Optional but recommended to avoid rate limits
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Optional: override table names (defaults shown)
# VECTOR_COLLECTION=tweet_examples
# VECTOR_REJECTION_COLLECTION=tweet_rejections

# Optional: Google Drive upload support for X videos.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_REDIRECT_URI=http://127.0.0.1:8787/oauth2callback

# Optional: service-account alternative for Shared Drives.
# GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON_PATH=
